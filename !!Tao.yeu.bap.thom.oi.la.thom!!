-- THUẬT TOÁN ULTRA HARD LOCK KHÓA VÀO THÂN (BODY)
----------------------------------------------------
local function findTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local rootPos = char.HumanoidRootPart.Position
    local camLook = Camera.CFrame.LookVector
    
    local bestTarget = nil
    local bestDist = math.huge
    
    for _, plr in ipairs(Players:GetPlayers()) do
        -- Bỏ qua bản thân và những người nằm trong danh sách tắt Hitbox
        if plr ~= LocalPlayer and not ignoredPlayers[plr] and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChild("Humanoid")
            
            if root and hum and hum.Health > 0 then
                local dist = (root.Position - rootPos).Magnitude
                if dist > AIM_RANGE then continue end
                
                local dir = (root.Position - rootPos).Unit
                local angle = math.acos(math.clamp(dir:Dot(camLook), -1, 1))
                
                if angle <= math.rad(AIM_FOV) and dist < bestDist then
                    bestDist = dist
                    bestTarget = {player = plr, body = root}
                end
            end
        end
    end
    return bestTarget
end

local function onHeartbeat()
    if not aiming or not target or not target.body or not target.body.Parent or ignoredPlayers[target.player] then
        aiming = false
        target = nil
        aimActionButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        aimActionButton.Text = "AIM"
        if aimConnection then aimConnection:Disconnect() aimConnection = nil end
        return
    end

    local bodyPos = target.body.Position
    local currentPos = Camera.CFrame.Position
    Camera.CFrame = CFrame.lookAt(currentPos, bodyPos)
end

aimActionButton.MouseButton1Click:Connect(function()
    if not aimEnabled then return end
    
    aiming = not aiming
    if aiming then
        target = findTarget()
        if target then
            aimActionButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
            aimActionButton.Text = "LOCK"
            if aimConnection then aimConnection:Disconnect() end
            aimConnection = RunService.Heartbeat:Connect(onHeartbeat)
        else
            aiming = false
        end
    else
        if aimConnection then aimConnection:Disconnect() aimConnection = nil end
        target = nil
        aimActionButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        aimActionButton.Text = "AIM"
    end
end)

