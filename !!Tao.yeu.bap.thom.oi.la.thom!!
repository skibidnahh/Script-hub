-- Update FPS/Ping
local lastUpdate = os.clock()
local frameCount = 0
RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    local now = os.clock()
    if now - lastUpdate >= 0.5 then
        local fps = math.floor(frameCount / (now - lastUpdate))
        fpsLabel.Text = "FPS: " .. fps
        fpsLabel.TextColor3 = (fps >= 50) and Color3.fromRGB(46, 204, 113) or ((fps >= 30) and Color3.fromRGB(241, 196, 15) or Color3.fromRGB(231, 76, 60))
        frameCount = 0
        lastUpdate = now
    end
end)

