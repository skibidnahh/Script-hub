local function CreateMatrixRain(parentFrame, isUI)
    local rainFrame = Instance.new("Frame", parentFrame)
    rainFrame.Size = UDim2.new(1, 0, 1, 0)
    rainFrame.BackgroundTransparency = 1
    rainFrame.ZIndex = isUI and 1 or 5
    rainFrame.ClipsDescendants = true

    local columns = {}
    local charSize = 14
    local colors = { Color3.fromRGB(0, 255, 65), Color3.fromRGB(0, 180, 40), Color3.fromRGB(0, 100, 20) }

    local width = isUI and 600 or Camera.ViewportSize.X
    local height = isUI and 450 or Camera.ViewportSize.Y
    local numColumns = math.ceil(width / (charSize * 0.8))
    if numColumns == 0 then numColumns = 80 end

    for i = 1, numColumns do
        local label = Instance.new("TextLabel", rainFrame)
        label.Size = UDim2.new(0, charSize, 1, 0)
        label.Position = UDim2.new(0, (i-1) * (charSize * 0.8), 0, 0)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.Code
        label.TextSize = charSize
        label.TextXAlignment = Enum.TextXAlignment.Center
        label.TextYAlignment = Enum.TextYAlignment.Top
        label.ZIndex = isUI and 1 or 5
        label.Text = ""

        columns[i] = { label = label, speed = math.random(100, 250), offset = math.random(-500, 0) }
    end

    local conn = RunService.Heartbeat:Connect(function(dt)
        for i, col in ipairs(columns) do
            col.offset = col.offset + col.speed * dt
            if col.offset > height then
                col.offset = -charSize * math.random(2, 8)
                col.speed = math.random(100, 250)
            end
            col.label.Position = UDim2.new(0, col.label.Position.X.Offset, 0, col.offset)
            local numChars = math.ceil(math.clamp(height - col.offset, 0, height) / charSize)
            local str = ""
            for _ = 1, math.min(numChars, 25) do str = str .. (math.random(0, 1) == 0 and "0" or "1") .. "\n" end
            col.label.Text = str
            col.label.TextColor3 = colors[math.random(#colors)]
        end
    end)

    return function() if conn then conn:Disconnect() end; rainFrame:Destroy() end
end

