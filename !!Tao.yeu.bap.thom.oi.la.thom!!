RunService.Heartbeat:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local char = plr.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            
            -- LOGIC MỚI: Kiểm tra danh sách bỏ qua (Whitelist)
            if ignoredPlayers[plr] then
                if root then
                    root.Size = Vector3.new(2, 2, 1)
                    root.Transparency = 1
                    root.CanCollide = true
                    root.Material = Enum.Material.Plastic
                end
            else
                -- LOGIC HITBOX BÌNH THƯỜNG
                if enabled and root then
                    root.Size = Vector3.new(size, size, size)
                    root.CanCollide = false
                    
                    if showVisual then
                        root.Transparency = 0.65 
                        root.Color = Color3.fromHex("#C0C0C0") 
                        root.Material = Enum.Material.Neon 
                    else
                        root.Transparency = 1
                        root.Material = Enum.Material.Plastic
                    end
                elseif not enabled and root then
                    root.Size = Vector3.new(2, 2, 1)
                    root.Transparency = 1
                end
            end

            -- LOGIC ESP
            if espEnabled then
                local hl = char:FindFirstChild("HitboxESP")
                if not hl then
                    hl = Instance.new("Highlight")
                    hl.Name = "HitboxESP"
                    hl.FillColor = Color3.fromRGB(231, 76, 60)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.6
                    hl.OutlineTransparency = 0
                    hl.Parent = char
                end
            end
        end
    end
end)
