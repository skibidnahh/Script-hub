local lastUpdate = os.clock()
local frameCount = 0
RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    local now = os.clock()
    if now - lastUpdate >= 0.5 then
        local fps = math.floor(frameCount / (now - lastUpdate))
        fpsLabel.Text = "FPS: " .. fps
        
        -- Logic chuyển màu FPS nhạy bén
        if fps >= 50 then
            fpsLabel.TextColor3 = Color3.fromRGB(46, 204, 113) -- Xanh mượt
        elseif fps >= 30 then
            fpsLabel.TextColor3 = Color3.fromRGB(241, 196, 15) -- Vàng hơi khựng
        else
            fpsLabel.TextColor3 = Color3.fromRGB(231, 76, 60)  -- Đỏ sụt nguồn
        end
        
        frameCount = 0
        lastUpdate = now
    end
end)

