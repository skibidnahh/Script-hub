}
KaoyaUI.CurrentTheme = Themes[currentThemeName] or Themes.Dark

local function cTween(obj, info, property)
    local t = TweenService:Create(obj, TweenInfo.new(info.Time or 0.25, info.Style or Enum.EasingStyle.Quad, info.Dir or Enum.EasingDirection.Out), property)
    t:Play()
    return t
end

function KaoyaUI:Register(obj, property, themeKey)
    self.Registry[obj] = self.Registry[obj] or {}
    self.Registry[obj][property] = themeKey
    obj[property] = self.CurrentTheme[themeKey]
    if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then obj.Font = self.CurrentTheme.Font end
    if themeKey == "Accent" or themeKey == "StrokeColor" then table.insert(self.PulseObjects, {obj = obj, property = property, baseKey = themeKey}) end
end

local function UpdateEffects()
    for _, s in ipairs(glowStrokes) do s:Destroy() end
    glowStrokes = {}
    for _, g in ipairs(gradients) do g:Destroy() end
    gradients = {}

    if glowEnabled and mainUIFrame and sidebarFrame then
        local g1 = Instance.new("UIStroke", mainUIFrame)
        g1.Color = KaoyaUI.CurrentTheme.Accent; g1.Thickness = 3; g1.Transparency = 0.5; g1.Name = "GlowStroke"
        table.insert(glowStrokes, g1)
    end

    if gradientEnabled and mainUIFrame and sidebarFrame then
        local grad1 = Instance.new("UIGradient", mainUIFrame)
        grad1.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, KaoyaUI.CurrentTheme.Secondary), ColorSequenceKeypoint.new(1, KaoyaUI.CurrentTheme.Main)})
        table.insert(gradients, grad1)
    end

    if dynamicConnection then dynamicConnection:Disconnect(); dynamicConnection = nil end

    if (borderAnimEnabled or accentPulseEnabled) and wStroke and sStroke then
        local startTime = tick()
        dynamicConnection = RunService.Heartbeat:Connect(function()
            local dt = tick() - startTime
            if borderAnimEnabled then
                local c = Color3.fromHSV((dt * 120) % 1, 0.8, 1)
                wStroke.Color = c; sStroke.Color = c
            end
            if accentPulseEnabled then
                local factor = (math.sin(dt * 4) + 1) / 2
                local newColor = KaoyaUI.CurrentTheme.Accent:Lerp(Color3.fromRGB(255,255,255), factor * 0.3)
                for _, item in ipairs(KaoyaUI.PulseObjects) do pcall(function() item.obj[item.property] = newColor end) end
            end
        end)
    end
end

function KaoyaUI:ApplyTheme(themeTable, themeName)
    self.CurrentTheme = themeTable
    if themeName then currentThemeName = themeName end
    for obj, props in pairs(self.Registry) do
        pcall(function()
            local targets = {}
            for prop, key in pairs(props) do targets[prop] = themeTable[key] end
            cTween(obj, {Time = 0.3}, targets)
            if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then obj.Font = themeTable.Font end
        end)
    end
    if openBtn then openBtn.Text = themeTable.Icon end
    UpdateEffects()
    SaveCurrentState()
end

