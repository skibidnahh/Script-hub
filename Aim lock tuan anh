-- ================== AIM LOCK FUNCTIONS ==================
local function AimIsProtected(otherPlayer)
    if AimProtected[otherPlayer.Name] then return true end
    if AimProtected["__ALL_TEAM__"] then
        if Player.Team and otherPlayer.Team then return Player.Team == otherPlayer.Team end
        if Player.TeamColor and otherPlayer.TeamColor then return Player.TeamColor == otherPlayer.TeamColor end
    end
    return false
end

local function AimGetHeadPosition(character)
    if character:FindFirstChild("Head") then return character.Head.Position end
    if character:FindFirstChild("HumanoidRootPart") then
        return character.HumanoidRootPart.Position + Vector3.new(0, 2, 0)
    end
    return nil
end

local function AimIsTargetValid(t)
    if not t or not t.Character then return false end
    local humanoid = t.Character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    if AimIsProtected(t) then return false end
    
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local targetRoot = t.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return false end
    
    local distance = (targetRoot.Position - char.HumanoidRootPart.Position).Magnitude
    if distance > AIM_RANGE then return false end
    
    return true
end

local function AimFindBestTarget()
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = char.HumanoidRootPart.Position
    local cam = workspace.CurrentCamera
    local camPos = cam.CFrame.Position
    local camLook = cam.CFrame.LookVector
    
    local bestTarget = nil
    local bestScore = -math.huge
    
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= Player and not AimIsProtected(plr) then
            if plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                local root = plr.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local targetPos = AimGetHeadPosition(plr.Character)
                    if not targetPos then continue end
                    
                    local distance = (root.Position - myPos).Magnitude
                    if distance > AIM_RANGE then continue end
                    
                    local dir = (targetPos - camPos).Unit
                    local angle = math.acos(math.clamp(dir:Dot(camLook), -1, 1))
                    
                    if angle <= math.rad(AIM_FOV) then
                        local score = (1000 - distance) - (math.deg(angle) * 5)
                        if score > bestScore then
                            bestScore = score
                            bestTarget = plr
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

local function AimShouldSwitchTarget()
    if not AimTarget or not AimTarget.Character then return true end
    
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    
    local targetRoot = AimTarget.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return true end
    
    local myPos = char.HumanoidRootPart.Position
    local currentDist = (targetRoot.Position - myPos).Magnitude
    
    if currentDist > AIM_RANGE then return true end
    
    local betterTarget = AimFindBestTarget()
    if betterTarget and betterTarget ~= AimTarget then
        local betterRoot = betterTarget.Character:FindFirstChild("HumanoidRootPart")
        if betterRoot then
            local newDist = (betterRoot.Position - myPos).Magnitude
            if newDist < currentDist - 10 then
                AimTarget = betterTarget
                AimLastPosition = betterRoot.Position
                AimSwitchCooldown = tick()
                return false
            end
            if newDist < PRIORITY_DISTANCE_THRESHOLD and newDist < currentDist then
                AimTarget = betterTarget
                AimLastPosition = betterRoot.Position
                AimSwitchCooldown = tick()
                return false
            end
        end
    end
    
    return false
end

local function AimSwitchToNewTarget()
    if not IsAimLock then return end
    if tick() - AimSwitchCooldown < AUTO_SWITCH_DELAY then return end
    
    local newTarget = AimFindBestTarget()
    if newTarget then
        if not AimTarget or newTarget ~= AimTarget then
            AimTarget = newTarget
            if newTarget.Character and newTarget.Character:FindFirstChild("HumanoidRootPart") then
                AimLastPosition = newTarget.Character.HumanoidRootPart.Position
            end
            AimSwitchCooldown = tick()
        end
    else
        AimTarget = nil
        AimLastPosition = nil
    end
end

local function AimOnRenderStep()
    if not IsAimLock then
        if AimConnection then AimConnection:Disconnect(); AimConnection = nil end
        return
    end
    
    if not AimIsTargetValid(AimTarget) then
        AimSwitchToNewTarget()
    else
        if AimShouldSwitchTarget() then AimSwitchToNewTarget() end
    end
    
    if AimTarget and AimTarget.Character then
        local targetPos = AimGetHeadPosition(AimTarget.Character)
        if targetPos then
            workspace.CurrentCamera.CFrame = CFrame.lookAt(workspace.CurrentCamera.CFrame.Position, targetPos)
        end
    end
end

local function StartAimLock()
    IsAimLock = true
    AimTarget = AimFindBestTarget()
    if AimTarget and AimTarget.Character and AimTarget.Character:FindFirstChild("HumanoidRootPart") then
        AimLastPosition = AimTarget.Character.HumanoidRootPart.Position
    end
    AimSwitchCooldown = tick()
    if AimConnection then AimConnection:Disconnect() end
    AimConnection = RunService.RenderStepped:Connect(AimOnRenderStep)
end

local function StopAimLock()
    IsAimLock = false
    AimTarget = nil
    AimLastPosition = nil
    if AimConnection then
        AimConnection:Disconnect()
        AimConnection = nil
    end
end

